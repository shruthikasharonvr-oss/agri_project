# Email Configuration (Nodemailer - Gmail)
# CRITICAL: You must configure these for OTP emails to work
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords (16 characters)
# 3. Copy the app password below (no spaces)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_character_app_password

# Firebase Web SDK (public keys, safe for frontend)
# Optional: Only needed if using Firebase for other features
NEXT_PUBLIC_FIREBASE_API_KEY=your_public_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Admin SDK (optional - removed from OTP flow)
# FIREBASE_PROJECT_ID=your_firebase_project_id
# FIREBASE_PRIVATE_KEY=your_firebase_private_key
# FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# ⚠️ SECURITY: Keep EMAIL_USER and EMAIL_PASS confidential
# ⚠️ Always add .env.local to .gitignore (never commit credentials)
