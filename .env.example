# ==========================================
# PUBLIC VARIABLES (Exposed to the frontend)
# ==========================================

# Supabase (Public)
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL_HERE
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# ==========================================
# PRIVATE VARIABLES (Server-side ONLY)
# ==========================================

# Supabase (Private/Admin)
# NEVER prefix with NEXT_PUBLIC_. This grants full bypass of RLS policies.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# Google OAuth (For Google Sign-In)
# NEVER prefix the Client Secret with NEXT_PUBLIC_. Keep it strictly backend.
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# Google Cloud Translation API
GOOGLE_CLOUD_API_KEY=YOUR_GOOGLE_CLOUD_API_KEY_HERE

# Nodemailer / SMTP settings 
# For Gmail, go to Google Account Security -> 2-Step Verification -> App Passwords
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
